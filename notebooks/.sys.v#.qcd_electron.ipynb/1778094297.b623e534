   "source": [
    "# ... (tu código de cálculo de h_qcd anterior) ...\n",
    "\n",
    "# Empaquetar QCD para el Plotter\n",
    "h_qcd_formatted = hist.Hist(\n",
    "    hist.axis.StrCategory([\"nominal\"], name=\"variation\"),\n",
    "    hist.axis.StrCategory([category], name=\"category\"), # Ej: \"electron\" o la que uses\n",
    "    h_qcd.axes[0],\n",
    "    storage=hist.storage.Weight()\n",
    ")\n",
    "h_qcd_formatted[{\"variation\": \"nominal\", \"category\": category}] = h_qcd.view()\n",
    "\n",
    "# Agregar al diccionario de salida\n",
    "out_final = out.copy() # out son tus histogramas de MC/Data cargados\n",
    "out_final[\"QCD\"] = {variable_qcd: h_qcd_formatted}\n",
    "\n",
    "# Instanciar y graficar\n",
    "plotter = CoffeaPlotter(\n",
    "    workflow=\"tu_workflow\",\n",
    "    year=\"2017\",\n",
    "    processed_histograms=out_final, # Aquí pasas el dict con QCD incluido\n",
    "    output_dir=\"./plots\"\n",
    ")\n",
    "\n",
    "# MUY IMPORTANTE: Asegúrate de que el color_map.yaml tenga la entrada \"QCD\"\n",
    "# O fuerza el color aquí:\n",
    "plotter.color_map[\"QCD\"] = \"#999999\" \n",
    "\n",
    "plotter.plot_histograms(\n",
    "    variable=variable_qcd,\n",
    "    category=category,\n",
    "    log=True\n",
    ")"
