    "# --- CONFIGURACIÓN ---\n",
    "category_name = \"1LnT1T\"  # <--- SUSTITUYE ESTO por el nombre de tu categoría\n",
    "variable_name = \"electron_met_mass\" # El nombre de la variable en el diccionario\n",
    "\n",
    "# --- FORMATEO DE QCD ---\n",
    "import hist\n",
    "\n",
    "h_qcd_formatted = hist.Hist(\n",
    "    hist.axis.StrCategory([\"nominal\"], name=\"variation\"),\n",
    "    hist.axis.StrCategory([category_name], name=\"category\"),\n",
    "    h_qcd.axes[0],\n",
    "    storage=hist.storage.Weight()\n",
    ")\n",
    "\n",
    "# Llenamos los datos calculados en el paso anterior\n",
    "h_qcd_formatted[{\"variation\": \"nominal\", \"category\": category_name}] = h_qcd.view()\n",
    "\n",
    "# --- INYECCIÓN EN EL DICCIONARIO ---\n",
    "# Suponiendo que 'out' es el diccionario que cargaste con load_hists\n",
    "out[\"QCD\"] = {variable_name: h_qcd_formatted}"
   ]
