   "id": "e538fbc7-81a5-40f1-9e76-c9813dfcbb79",
   "metadata": {},
   "outputs": [],
   "source": [
    "class CoffeaPlotter:\n",
    "    def __init__(self, workflow, year, processed_histograms, output_dir):\n",
    "        # ... (tu __init__ original se mantiene igual) ...\n",
    "        self.workflow = workflow\n",
    "        self.year = year\n",
    "        self.processed_histograms = processed_histograms\n",
    "        self.output_dir = output_dir\n",
    "        # ... (restaurar carga de configs y luminosidades aquí) ...\n",
    "\n",
    "    def get_histogram(self, variable, variation, category, histogram):\n",
    "        selector = {}\n",
    "        if \"variation\" in histogram.axes.name:\n",
    "            selector.update({\"variation\": variation})\n",
    "        if \"category\" in histogram.axes.name:\n",
    "            selector[\"category\"] = category\n",
    "        \n",
    "        # PROYECCIÓN LIMPIA: Sin división por bin width\n",
    "        return histogram[selector].project(variable)\n",
    "\n",
    "    def collect_histograms_for_plotting(self, variable, category, blind):\n",
    "        histogram_info = {\"mc\": {\"nominal\": {}, \"variations\": {}}}\n",
    "        if \"signal\" in self.datasets:\n",
    "            histogram_info[\"signal\"] = {\"nominal\": {}}\n",
    "\n",
    "        for process, histogram_dict in self.processed_histograms.items():\n",
    "            # Buscar el histograma en el diccionario\n",
    "            aux_histogram = None\n",
    "            if variable in histogram_dict:\n",
    "                aux_histogram = histogram_dict[variable]\n",
    "            else:\n",
    "                for key in histogram_dict:\n",
    "                    if variable in histogram_dict[key].axes.name:\n",
    "                        aux_histogram = histogram_dict[key]\n",
    "                        break\n",
    "            \n",
    "            if aux_histogram is None: continue\n",
    "\n",
    "            if process == \"Data\":\n",
    "                histogram_info[\"data\"] = self.get_histogram(variable, \"nominal\", category, aux_histogram)\n",
    "            else:\n",
    "                # Determinar si es MC o Signal\n",
    "                is_signal = self.process_name_map[process].startswith(\"signal\")\n",
    "                key = \"signal\" if is_signal else \"mc\"\n",
    "                \n",
    "                histogram_info[key][\"nominal\"][process] = self.get_histogram(\n",
    "                    variable, \"nominal\", category, aux_histogram\n",
    "                )\n",
    "                # NOTA: Se ha eliminado el bloque de 'variations' (Up/Down)\n",
    "                \n",
    "        return histogram_info\n",
    "\n",
    "    def plot_uncert_band(self, histogram_info, ax):\n",
    "        # Como variaciones está vacío, solo usamos el error estadístico (variances)\n",
    "        err2 = self.nominal_variances\n",
    "        self.style[\"uncert_band_kwargs\"][\"label\"] = \"Stat unc\"\n",
    "\n",
    "        self.band_up = self.nominal_values + np.sqrt(err2)\n",
    "        self.band_down = self.nominal_values - np.sqrt(err2)\n",
    "        \n",
    "        ax.bar(\n",
    "            x=self.centers,\n",
    "            height=self.band_up - self.band_down,\n",
    "            width=self.widths,\n",
    "            bottom=self.band_down,\n",
    "            **self.style[\"uncert_band_kwargs\"],\n",
    "        )"
   ]
  },
  {
   "cell_type": "code",
