   ],
   "source": [
    "out = load_hists(\"2017\",\"qcd_tf_ele\")\n",
    "data = out[\"Data\"][\"transverse_mass\"][{\"variation\": \"nominal\"}]\n",
    "mc = accumulate([\n",
    "    out[\"DYJetsToLL\"][\"transverse_mass\"][{\"variation\": \"nominal\"}],\n",
    "    out[\"SingleTop\"][\"transverse_mass\"][{\"variation\": \"nominal\"}],\n",
    "    out[\"tt\"][\"transverse_mass\"][{\"variation\": \"nominal\"}],\n",
    "    out[\"Diboson\"][\"transverse_mass\"][{\"variation\": \"nominal\"}]\n",
    "])\n",
    "histo = data + (mc * -1)\n",
    "variable_tf = \"electron_met_mass_leading\"\n",
    "h_Tight = histo[{\"category\": \"1LnT1T\"}].project(variable_tf)\n",
    "h_nTight = histo[{\"category\": \"1LnT1nT\"}].project(variable_tf)\n",
    "num = h_Tight.values()\n",
    "den = h_nTight.values()\n",
    "var_num = h_Tight.variances()\n",
    "var_den = h_nTight.variances()\n",
    "tf = np.where(\n",
    "    (num > 0) & (den > 0), \n",
    "    num / (den + 1e-32),\n",
    "    1\n",
    ")\n",
    "tf_var = np.zeros_like(tf)\n",
    "mask = den != 0\n",
    "tf_var[mask] = (\n",
    "    (1.0 / den[mask])**2 * var_num[mask]\n",
    "    +\n",
    "    (num[mask] / den[mask]**2)**2 * var_den[mask]\n",
    ")\n",
    "\n",
    "h_tf = h_Tight.copy()\n",
    "h_tf.values()[:] = tf\n",
    "h_tf.variances()[:] = tf_var\n",
    "\n",
    "#######QCD STIMATION\n",
    "out = load_hists(\"2017\",\"qcd_ele\")\n",
    "data = out[\"Data\"][\"transverse_mass\"][{\"variation\": \"nominal\"}]\n",
    "mc = accumulate([\n",
    "    out[\"DYJetsToLL\"][\"transverse_mass\"][{\"variation\": \"nominal\"}],\n",
    "    out[\"SingleTop\"][\"transverse_mass\"][{\"variation\": \"nominal\"}],\n",
    "    out[\"tt\"][\"transverse_mass\"][{\"variation\": \"nominal\"}],\n",
    "    out[\"Diboson\"][\"transverse_mass\"][{\"variation\": \"nominal\"}],\n",
    "    out[\"WJetsToLNu\"][\"transverse_mass\"][{\"variation\": \"nominal\"}]\n",
    "])\n",
    "histo = data + (mc * -1)\n",
    "variable_qcd = \"electron_met_mass\"\n",
    "\n",
    "h_loose_not_tight = histo.project(variable_qcd)\n",
    "h_qcd = h_loose_not_tight * tf\n",
    "print(histo.project(variable_qcd).values())"
   ]
  },
