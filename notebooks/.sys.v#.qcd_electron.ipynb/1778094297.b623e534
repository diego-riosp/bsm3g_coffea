     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[63897.98929479 28020.93462599 61451.87777535 50292.62256831\n",
      " 21931.83577626  9772.9196161  18833.83857121  7712.98021171\n",
      "   715.90341216]\n"
     ]
