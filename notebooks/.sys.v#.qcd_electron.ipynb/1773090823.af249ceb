   "source": [
    "out_qcd = load(f\"outputs/qcd_mu/{year}/{year}_processed_histograms.coffea\")\n",
    "data_qcd = out_qcd[\"Data\"][\"mass\"][{\"variation\":\"nominal\"}]\n",
    "mc_qcd = accumulate([\n",
    "    out_qcd[\"DYJetsToLL\"][\"mass\"][{\"variation\":\"nominal\"}],\n",
    "    out_qcd[\"SingleTop\"][\"mass\"][{\"variation\":\"nominal\"}],\n",
    "    out_qcd[\"tt\"][\"mass\"][{\"variation\":\"nominal\"}],\n",
    "    out_qcd[\"Diboson\"][\"mass\"][{\"variation\":\"nominal\"}],\n",
    "    out_qcd[\"WJetsToLNu\"][\"mass\"][{\"variation\":\"nominal\"}]\n",
    "])\n",
    "\n",
    "histo_qcd = data_qcd + (mc_qcd*-1) # este seria el que se calcula para qcd_mu\n",
    "\n",
    "# La estimacion final de QCD es: qcd_mu(MT) x qcd_tf_mu(MT)\n",
    "# histograma:\n",
    "# histo_qcd * tf"
   ]
  },
