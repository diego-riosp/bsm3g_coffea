   ],
   "source": [
    "data = out[\"Data\"][\"met\"][{\"variation\":\"nominal\"}]\n",
    "mc = accumulate([\n",
    "    out[\"WJetsToLNu\"][\"met\"][{\"variation\":\"nominal\"}],\n",
    "    out[\"SingleTop\"][\"met\"][{\"variation\":\"nominal\"}],\n",
    "    out[\"tt\"][\"met\"][{\"variation\":\"nominal\"}],\n",
    "    out[\"Diboson\"][\"met\"][{\"variation\":\"nominal\"}]\n",
    "])\n",
    "\n",
    "histo = data + (mc*-1) # este seria el que se calcula para qcd_mu\n",
    "v= \"met_pt\"\n",
    "one_tight_one_loose = histo[{\"category\":'1L1T'}].project(v).values()\n",
    "two_tight = histo[{\"category\":'2T'}].project(v).values()\n",
    "\n",
    "num = np.abs(two_tight)\n",
    "den = one_tight_one_loose\n",
    "\n",
    "\n",
    "ratio = num / den\n",
    "\n",
    "tf_met = np.where( # este es qcd_tf_mu(MT)\n",
    "    (num > 0) & (den > 0), \n",
    "    num / (den + 1e-32),\n",
    "    1\n",
    ")\n",
    "print(f\"Transfer factor:\\n{list(tf_met)}\")\n",
    "print()"
   ]
