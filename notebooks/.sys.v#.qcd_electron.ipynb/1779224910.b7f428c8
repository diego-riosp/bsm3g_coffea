   "source": [
    "# One Tight One not Tight"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "ed03ad82-50c6-443e-901d-f6ddbcb3080b",
   "metadata": {},
   "outputs": [
    {
