  {
   "cell_type": "code",
   "execution_count": 35,
   "id": "3bd5c56b-8f45-43ea-8ecc-a3bd1badf92a",
   "metadata": {},
   "outputs": [],
   "source": [
    "out_qcd = load(f\"outputs/qcd_ele/{year}/{year}_processed_histograms.coffea\")\n",
    "data_qcd = out_qcd[\"Data\"][\"mass\"][{\"variation\":\"nominal\"}]\n",
    "mc_qcd = accumulate([\n",
    "    out_qcd[\"DYJetsToLL\"][\"mass\"][{\"variation\":\"nominal\"}],\n",
    "    out_qcd[\"SingleTop\"][\"mass\"][{\"variation\":\"nominal\"}],\n",
    "    out_qcd[\"tt\"][\"mass\"][{\"variation\":\"nominal\"}],\n",
    "    out_qcd[\"Diboson\"][\"mass\"][{\"variation\":\"nominal\"}],\n",
    "    out_qcd[\"WJetsToLNu\"][\"mass\"][{\"variation\":\"nominal\"}]\n",
    "])\n",
    "\n",
    "histo_qcd = data_qcd + (mc_qcd*-1)\n",
    "\n",
    "# La estimacion final de QCD es: qcd_ele(MT) x qcd_tf_ele(MT)\n",
    "# histograma:\n",
    "qcd = histo_qcd * tf"
   ]
  },
