      "\u001b[0;31mKeyError\u001b[0m: \"'nominal' not in axis\""
     ]
    }
   ],
   "source": [
    "data = out[\"Data\"][\"transverse_mass\"][{\"variation\":\"nominal\"}]\n",
    "mc = accumulate([\n",
    "    out[\"DYJetsToLL\"][\"transverse_mass\"][{\"variation\":\"nominal\"}],\n",
    "    out[\"SingleTop\"][\"transverse_mass\"][{\"variation\":\"nominal\"}],\n",
    "    out[\"tt\"][\"transverse_mass\"][{\"variation\":\"nominal\"}],\n",
    "    out[\"Diboson\"][\"transverse_mass\"][{\"variation\":\"nominal\"}]\n",
    "])\n",
    "\n",
    "histo = data + (mc*-1)\n",
    "v= \"electron_met_mass\"\n",
    "\n",
    "one_tight_one_loose = histo[{\"category\":'al1T1Le'}].project(v).values()\n",
    "two_tight = histo[{\"category\":'al1Tb1Te'}].project(v).values()\n",
    "\n",
    "num = two_tight\n",
    "den = one_tight_one_loose\n",
    "\n",
    "ratio = num / den\n",
    "\n",
    "tf = np.where( \n",
    "    (num > 0) & (den > 0), \n",
    "    num / (den + 1e-32),\n",
    "    1\n",
    ")\n",
    "print(f\"Transfer factor:\\n{list(tf)}\")\n",
    "print()"
   ]
  },
