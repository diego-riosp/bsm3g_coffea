    "from analysis.postprocess.coffea_plotter import CoffeaPlotter\n",
    "from coffea.util import save, load\n",
    "from analysis.workflows.config import WorkflowConfigBuilder\n",
    "\n",
    "config_builder = WorkflowConfigBuilder(workflow=\"qcd_ele\")\n",
    "workflow_config = config_builder.build_workflow_config()\n",
    "\n",
    "output_dir = Path.cwd() / \"outputs\" / \"qcd_ele\" / \"2017\"\n",
    "postprocess_file = output_dir / f\"2017_processed_histograms.coffea\"\n",
    "processed_histograms = load(str(postprocess_file))\n",
    "\n",
    "plotter = CoffeaPlotter(\n",
    "    workflow=\"qcd_ele\",\n",
    "    processed_histograms=out,\n",
    "    year=\"2017\",\n",
    "    output_dir=output_dir,\n",
    ")\n",
    "\n",
    "# for category in workflow_config.event_selection[\"categories\"]:\n",
    "#     for variable in workflow_config.histogram_config.variables:\n",
    "#         plotter.plot_histograms(\n",
    "#             variable=variable,\n",
    "#             category=category,\n",
    "#             log=True,\n",
    "#             extension=\"png\",\n",
    "#             add_ratio=True,\n",
    "#             blind=False,\n",
    "#         )\n",
    "plotter.plot_histograms(\n",
    "        variable=\"electron_met_mass\",\n",
    "        category=\"base\",\n",
    "        log=True,\n",
    "        extension=\"png\",\n",
    "        add_ratio=True,\n",
    "        blind=False,\n",
    "    )"
   ]
