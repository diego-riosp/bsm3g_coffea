    "#     out[\"tt\"][\"mass\"][{\"variation\": \"nominal\"}],\n",
    "#     out[\"Diboson\"][\"mass\"][{\"variation\": \"nominal\"}]\n",
    "# ])\n",
    "\n",
    "# histo = data + (mc * -1)\n",
    "\n",
    "# variable = \"electron_met_mass\"\n",
    "\n",
    "# h_base = histo.project(variable)\n",
    "\n",
    "# h_qcd = h_base * tf\n",
    "\n",
    "#######################"
   ]
