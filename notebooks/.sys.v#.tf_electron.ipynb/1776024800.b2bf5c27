  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "e3168ccc-903e-4934-b1cb-d41092702bf3",
   "metadata": {},
   "outputs": [],
   "source": [
    "year = \"2017\"\n",
    "out = load(f\"outputs/qcd_ele/{year}/{year}_processed_histograms.coffea\")\n",
    "template = out[\"Data\"][\"mass\"]\n",
    "h_qcd_out = template.copy()\n",
    "h_qcd_out.reset()\n",
    "view = h_qcd_out.view()\n",
    "var_axis = h_qcd_out.axes[\"variation\"]\n",
    "idx_var = list(var_axis).index(\"nominal\")\n",
    "view.value[:, 0, idx_var] = h_qcd.values()\n",
    "view.variance[:, 0, idx_var] = h_qcd.variances()\n",
    "out[\"QCD\"] = {\"mass\": h_qcd_out}"
   ]
  },
